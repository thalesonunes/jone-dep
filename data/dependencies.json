      },
      {
        "group": "org.mapstruct",
        "name": "mapstruct-processor",
        "version": "1.5.3.Final",
        "configuration": "annotationProcessor",
        "declaration": "annotationProcessor 'org.mapstruct:mapstruct-processor:1.5.3.Final'"
      }
    ]
  },
